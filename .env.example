# ============================================================================
# X-alpha required secrets / env. Copy to .env for local dev, or set these as
# GitHub Actions secrets for CI. NEVER commit real values. Katomasa provides
# the secret values; this file only lists the names.
# ============================================================================

# --- Phase 1: X (Twitter) API, OAuth2 user context, scope: bookmark.read ---
# App credentials (from the X developer portal). Client secret only needed for
# confidential clients.
X_CLIENT_ID=
X_CLIENT_SECRET=
# The numeric X user id whose bookmarks are read (GET /2/users/:id/bookmarks).
# `npm run auth` prints this for you.
X_USER_ID=
# OAuth2 authorization settings (used by `npm run auth` only).
# The redirect URI must be registered verbatim in the X app's OAuth2 settings.
X_REDIRECT_URI=http://127.0.0.1:8723/callback
X_SCOPES=bookmark.read tweet.read users.read offline.access
# User-context tokens obtained via the OAuth2 PKCE authorization-code flow.
# The interactive user-consent step CANNOT be completed inside the CI/agent
# environment; run it once locally (see README "OAuth2 authorization") and put
# the resulting refresh token here. The client auto-refreshes the access token.
X_REFRESH_TOKEN=
# Optional: a still-valid access token to skip the first refresh.
X_ACCESS_TOKEN=

# --- Phase 2: claim extraction (Claude / Anthropic) ---
# Same key family as osd. Model id kept in sync with osd's config.
ANTHROPIC_API_KEY=
# Override the extraction model if needed (defaults in src/config/env.ts).
X_ALPHA_ANTHROPIC_MODEL=

# --- Phase 3: price data source (pluggable) ---
# Which adapter to use: "stooq" (no key) | "fixture" (offline tests).
X_ALPHA_PRICE_SOURCE=stooq
# If a keyed source is chosen later, add its key here and read it in
# src/score/priceSource.ts. Stooq needs no key.

# --- Phase 4: osd public API (read-only HTTP GET; osd is never modified) ---
OSD_US_PORTFOLIO_URL=https://osd-coral.vercel.app/api/alpha/portfolio/current
OSD_JP_PORTFOLIO_URL=https://osd-coral.vercel.app/api/alpha/jp/portfolio/current
